# ── Secrets — never commit ─────────────────────────────────────────────────────
*.env
.env
vault_pass.txt
*.key
*.pem
*.cry

# Ansible plaintext provisioning secrets — only the *.sops.yaml encrypted copy is committed
secrets.yaml
# Filled-in credential files (track only the .example templates)
ansible/playbooks/unifi/group_vars/unifi.yaml
ansible/playbooks/kubernetes/k3s/new/group_vars/vault.yml

# Terraform variable files (contain API tokens, passwords)
terraform.tfvars
*.tfvars
!*.tfvars.example

# Terraform state — local state is safe locally but must never be committed
terraform.tfstate
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl

# Packer — rendered HCL (generated from .j2) and variable files
packer/proxmox-iso-ubuntu/proxmox-iso-ubuntu.pkr.hcl
packer/proxmox-iso-ubuntu/proxmox.pkrvars.sh

# SOPS-encrypted secrets ARE safe to commit — un-ignore them.
# .env.sops files have age/AES256-GCM-encrypted values.
# See scripts/README.md for the full SOPS workflow.
!*.env.sops
!*.sops.yaml
!*.sops.tfvars

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── App runtime data (Docker volume mounts, never committed) ───────────────────
**/volumes/
**/data/
**/db/
**/run/
**/log/
**/logs/
**/ssh/
**/diagnostic.data/
**/journal/
data/
volumes/
secrets/

# ── Netboot large binaries (download fresh via web UI, never commit) ───────────
bootstrap/netbootxyz/assets/proxmox/vmlinuz
bootstrap/netbootxyz/assets/proxmox/initrd.img
bootstrap/netbootxyz/assets/asset-mirror/

# ── App-specific ───────────────────────────────────────────────────────────────
adguard/**/conf/*.yaml
crowdsec/config/hub/
promgraftail/grafana/
wazuh/wazuh_integrations

# ── Misc ───────────────────────────────────────────────────────────────────────
*.log
*.pid
*.sqlite
*.sock
.git
*.claude
.obsidian
# Hugo content/ is 100% generated from docs/ by sync.sh — never commit (regenerate on build)
docs/hugo/content/
# Hugo build output (regenerate with: cd docs/hugo && ./sync.sh && hugo build)
docs/hugo/public/
docs/hugo/.hugo_build.lock
docs/hugo/resources/
