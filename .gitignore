# ── Secrets — never commit ─────────────────────────────────────────────────────
*.env
.env

# Personal local-only checklist of secrets pasted in plaintext during a chat
# session, kept for the user's own credential-rotation follow-up — never commit.
ROTATE_CREDENTIALS.md

# Config-as-secret files decrypted onto a target host by sops-deploy — same
# pattern as .env/.env.example. The tracked placeholder is
# apps/docker/mailrise/mailrise.conf.example; this only excludes the real
# decrypted copy from ever being accidentally committed on a deploy target.
apps/docker/mailrise/mailrise.conf
# Same pattern — apps/docker/fasten-health/config.yaml.example is the tracked
# placeholder; the real file has a live JWT signing key.
apps/docker/fasten-health/config.yaml
# Same pattern — apps/docker/home-assistant/config/secrets.yaml.example is the
# tracked placeholder; the real file has the live Postgres recorder credentials.
apps/docker/home-assistant/config/secrets.yaml
vault_pass.txt
*.key
*.pem
*.cry

# Ansible plaintext provisioning secrets — only the *.sops.yaml encrypted copy is committed
secrets.yaml
# Filled-in credential files (track only the .example templates)
ansible/playbooks/unifi/group_vars/unifi.yaml
ansible/playbooks/kubernetes/k3s/new/group_vars/vault.yml

# Terraform variable files (contain API tokens, passwords)
terraform.tfvars
*.tfvars
!*.tfvars.example

# Terraform state — local state is safe locally but must never be committed
terraform.tfstate
terraform.tfstate.backup
.terraform/
# NOTE: .terraform.lock.hcl IS committed (provider version+hash pinning — supply-chain
# protection). Only the .terraform/ plugin cache dir is ignored.

# Packer — rendered HCL (generated from .j2) and variable files
packer/proxmox-iso-ubuntu/proxmox-iso-ubuntu.pkr.hcl
packer/proxmox-iso-ubuntu/proxmox.pkrvars.sh

# SOPS-encrypted secrets ARE safe to commit — un-ignore them.
# .env.sops files have age/AES256-GCM-encrypted values, as does any other
# *.sops file (config-as-secret services, e.g. mailrise.conf.sops — see
# ansible/playbooks/docker/sops-deploy/README.md).
# See scripts/README.md for the full SOPS workflow.
!*.env.sops
!*.sops.yaml
!*.sops
!*.sops.tfvars

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── App runtime data (Docker volume mounts, never committed) ───────────────────
**/volumes/
**/data/
**/db/
**/run/
**/log/
**/logs/
**/ssh/
**/diagnostic.data/
**/journal/
data/
volumes/
secrets/

# Traefik's hand-authored routing config lives under data/ alongside runtime
# state (acme.json, logs) that data/ is meant to exclude — track just these two.
!apps/docker/traefik/data/
apps/docker/traefik/data/*
!apps/docker/traefik/data/traefik.yml
!apps/docker/traefik/data/config.yml

# ── Netboot large binaries (download fresh via web UI, never commit) ───────────
bootstrap/netbootxyz/assets/proxmox/vmlinuz
bootstrap/netbootxyz/assets/proxmox/initrd.img
bootstrap/netbootxyz/assets/asset-mirror/

# ── App-specific ───────────────────────────────────────────────────────────────
adguard/**/conf/*.yaml
crowdsec/config/hub/
promgraftail/grafana/
wazuh/wazuh_integrations

# ── Misc ───────────────────────────────────────────────────────────────────────
*.log
*.pid
*.sqlite
*.sock
.git
*.claude
.obsidian
# Hugo content/ is 100% generated from docs/ by sync.sh — never commit (regenerate on build)
docs/hugo/content/
# Hugo build output (regenerate with: cd docs/hugo && ./sync.sh && hugo build)
docs/hugo/public/
docs/hugo/.hugo_build.lock
docs/hugo/resources/
