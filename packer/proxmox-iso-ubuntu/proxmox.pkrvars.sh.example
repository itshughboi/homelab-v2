# Packer build variables for proxmox-iso-ubuntu
# Copy to proxmox.pkrvars.sh and fill in values before running build.sh
#
# proxmox.pkrvars.sh is in .gitignore — never commit it.

# ── Proxmox connection ─────────────────────────────────────────────────────────
export PROXMOX_API_URL="https://10.10.10.1:8006/api2/json"
export PROXMOX_API_TOKEN_ID="packer@pve!packer"         # user@realm!tokenID
export PROXMOX_API_TOKEN_SECRET=""                       # from Vaultwarden
export PROXMOX_NODE="pve-srv-1"                         # Proxmox node to build on
export SKIP_TLS_VERIFY="true"                           # self-signed cert

# ── VM template settings ───────────────────────────────────────────────────────
export VM_ID="9999"                                     # Terraform clones from this ID
export IMAGE_NAME="ubuntu-server-noble"
export VM_DESCRIPTION="Ubuntu Server Noble (24.04) — k3s base image"

# ── Hardware ───────────────────────────────────────────────────────────────────
export CPU_CORES="2"
export MEMORY_MB="2048"
export DISK_SIZE="25G"
export DISK_STORAGE="local-lvm"
export NETWORK_BRIDGE="vmbr0"
export CLOUDINIT_STORAGE="local-lvm"

# ── ISO source ─────────────────────────────────────────────────────────────────
# Use "local" if the ISO is already uploaded to Proxmox storage
# Use "download" to have Packer fetch it from the URL below
export ISO_SOURCE="local"
export ISO_FILE="local:iso/ubuntu-24.04.2-live-server-amd64.iso"
export ISO_CHECKSUM="sha256:d6dab0c40ef5a3ed5a5c80ad35ffd6ca5f50deb19e6d7e78a93ac2e5a75af6e"

# For download source (comment out ISO_FILE above):
# export ISO_SOURCE="download"
# export ISO_URL="https://releases.ubuntu.com/24.04/ubuntu-24.04.2-live-server-amd64.iso"
# export ISO_STORAGE="local"

# ── SSH (used by Packer to connect during provisioning) ───────────────────────
export SSH_USERNAME="hughboi"
export SSH_AUTH_METHOD="password"
export SSH_PASSWORD=""                                  # temp password — changed by cloud-init on first boot
export SSH_TIMEOUT="30m"

# ── Cloud-init defaults baked into the template ────────────────────────────────
export LOCALE="en_US"
export KEYBOARD_LAYOUT="us"
export TIMEZONE="America/Denver"

# ── HTTP server (Packer serves autoinstall config via HTTP) ───────────────────
export HTTP_BIND_ADDRESS="0.0.0.0"
export HTTP_PORT_MIN="8802"
export HTTP_PORT_MAX="8802"
export BOOT_WAIT="5s"
